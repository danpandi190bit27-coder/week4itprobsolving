import java.util.*;
import java.io.*;

public class Solution {
    public static void countSort(List<List<String>> arr) {
        int n = arr.size();
        // Since constraints say integers are in range [0, 100)
        StringBuilder[] buckets = new StringBuilder[100];
        
        // Initialize buckets
        for (int i = 0; i < 100; i++) {
            buckets[i] = new StringBuilder();
        }

        for (int i = 0; i < n; i++) {
            int key = Integer.parseInt(arr.get(i).get(0));
            String value = arr.get(i).get(1);

            // Twist: Replace first half strings with "-"
            if (i < n / 2) {
                value = "-";
            }

            // Append to the correct bucket with a trailing space
            buckets[key].append(value).append(" ");
        }

        // Print all buckets in order
        StringBuilder result = new StringBuilder();
        for (StringBuilder bucket : buckets) {
            result.append(bucket);
        }
        
        System.out.println(result.toString().trim());
    }

    public static void main(String[] args) throws IOException {
        // Fast I/O is recommended for large input sizes (up to 1,000,000)
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        int n = Integer.parseInt(br.readLine().trim());
        List<List<String>> arr = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            arr.add(Arrays.asList(br.readLine().split(" ")));
        }

        countSort(arr);
    }
}
